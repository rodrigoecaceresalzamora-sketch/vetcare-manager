# ============================================================
# VetCare Manager — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# NUNCA subas .env.local a Git
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Encuéntralos en: supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Solo para Edge Functions (nunca en el frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Email con Resend ──────────────────────────────────────────
# Créate una cuenta en resend.com → API Keys → Create
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dominio verificado en Resend (o usa onboarding@resend.dev para pruebas)
EMAIL_DOMAIN=tuclinica.cl

# ── Google Calendar (OAuth2) ──────────────────────────────────
# Consola de Google: console.cloud.google.com → Credenciales → OAuth 2.0
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxx
VITE_GOOGLE_CALENDAR_ID=primary
# URI de redirección OAuth (debe coincidir con la configurada en Google)
GOOGLE_REDIRECT_URI=https://tudominio.cl/auth/google/callback

# ── URLs de la app ────────────────────────────────────────────
VITE_APP_URL=https://vetcare.tudominio.cl
# URL del portal público de agendamiento (ruta /reserva)
VITE_BOOKING_URL=https://vetcare.tudominio.cl/reserva
